{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.studioveinard.fr" }],
      "destination": "https://studioveinard.fr/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(assets|uploads)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(favicon.ico|apple-touch-icon.png|icon-192.png|icon-512.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    }
  ]
}
